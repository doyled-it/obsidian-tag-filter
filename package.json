{
  "name": "obsidian-tag-filter",
  "version": "0.1.0",
  "description": "Interactive tag picker to filter checkbox items by their inline tags",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "obsidian": "latest"
  }
}
